# Postgres connection string for Drizzle/app backend
DATABASE_URL=postgres://postgres:password@localhost:5432/lingua_connect

# API URL for Expo mobile devices on the same Wi-Fi as your dev machine
EXPO_PUBLIC_API_URL=http://192.168.1.5:5000/

# OpenAI API Key - Get yours from https://platform.openai.com/api-keys
OPENAI_API_KEY=your-openai-api-key-here

# Optional: Custom OpenAI Base URL (for proxies)
# OPENAI_BASE_URL=https://api.openai.com/v1

